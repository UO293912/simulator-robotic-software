#include <Braccio.h>
#include <Servo.h>

// Objetos requeridos por la libreria Braccio.
Servo base;
Servo shoulder;
Servo elbow;
Servo wrist_ver;
Servo wrist_rot;
Servo gripper;

const int STEP_DELAY_MS = 20;

// M2 no se barre: se mantiene fijo porque ahora mismo no transmite
// el giro a la articulacion real del hombro.
const int FIXED_M2_ANGLE = 45;

const int M1_MIN = 0;
const int M1_MAX = 180;
const int M3_MIN = 0;
const int M3_MAX = 180;
const int M4_MIN = 0;
const int M4_MAX = 180;
const int M5_MIN = 0;
const int M5_MAX = 180;
const int M6_MIN = 10;
const int M6_MAX = 73;

int currentM1 = 90;
int currentM3 = 180;
int currentM4 = 180;
int currentM5 = 90;
int currentM6 = 10;

int selectedMotor = 1;
int angleStep = 5;

void applyPose() {
  Braccio.ServoMovement(
    STEP_DELAY_MS,
    currentM1,
    FIXED_M2_ANGLE,
    currentM3,
    currentM4,
    currentM5,
    currentM6
  );
}

const char* labelForMotor(int motor) {
  switch (motor) {
    case 1:
      return "base";
    case 3:
      return "elbow";
    case 4:
      return "wrist vertical";
    case 5:
      return "wrist rotation";
    case 6:
      return "gripper";
    default:
      return "unknown";
  }
}

int minAngleForMotor(int motor) {
  switch (motor) {
    case 1:
      return M1_MIN;
    case 3:
      return M3_MIN;
    case 4:
      return M4_MIN;
    case 5:
      return M5_MIN;
    case 6:
      return M6_MIN;
    default:
      return 0;
  }
}

int maxAngleForMotor(int motor) {
  switch (motor) {
    case 1:
      return M1_MAX;
    case 3:
      return M3_MAX;
    case 4:
      return M4_MAX;
    case 5:
      return M5_MAX;
    case 6:
      return M6_MAX;
    default:
      return 180;
  }
}

int angleForMotor(int motor) {
  switch (motor) {
    case 1:
      return currentM1;
    case 3:
      return currentM3;
    case 4:
      return currentM4;
    case 5:
      return currentM5;
    case 6:
      return currentM6;
    default:
      return 0;
  }
}

void setAngleForMotor(int motor, int value) {
  switch (motor) {
    case 1:
      currentM1 = value;
      break;
    case 3:
      currentM3 = value;
      break;
    case 4:
      currentM4 = value;
      break;
    case 5:
      currentM5 = value;
      break;
    case 6:
      currentM6 = value;
      break;
  }
}

void printHelp() {
  Serial.println();
  Serial.println(F("Comandos:"));
  Serial.println(F("  1,3,4,5,6 -> seleccionar motor"));
  Serial.println(F("  d o +     -> subir angulo del motor seleccionado"));
  Serial.println(F("  a o -     -> bajar angulo del motor seleccionado"));
  Serial.println(F("  z         -> paso de 1 grado"));
  Serial.println(F("  x         -> paso de 5 grados"));
  Serial.println(F("  c         -> paso de 10 grados"));
  Serial.println(F("  p         -> imprimir angulos actuales"));
  Serial.println(F("  r         -> volver a la pose base"));
  Serial.println(F("  h o ?     -> mostrar ayuda"));
  Serial.println();
  Serial.println(F("Consejo: acerca el limite con paso 10 o 5, y afinado final con paso 1."));
  Serial.println(F("Cuando veas el limite fisico real, apunta el angulo mostrado y retrocede un paso."));
}

void printPose() {
  Serial.println();
  Serial.print(F("Motor seleccionado: M"));
  Serial.print(selectedMotor);
  Serial.print(F(" ("));
  Serial.print(labelForMotor(selectedMotor));
  Serial.println(F(")"));

  Serial.print(F("Paso actual: "));
  Serial.print(angleStep);
  Serial.println(F(" grados"));

  Serial.print(F("M1 base = "));
  Serial.println(currentM1);
  Serial.print(F("M2 shoulder fijo = "));
  Serial.println(FIXED_M2_ANGLE);
  Serial.print(F("M3 elbow = "));
  Serial.println(currentM3);
  Serial.print(F("M4 wrist vertical = "));
  Serial.println(currentM4);
  Serial.print(F("M5 wrist rotation = "));
  Serial.println(currentM5);
  Serial.print(F("M6 gripper = "));
  Serial.println(currentM6);

  Serial.println(F("Nota: los angulos mostrados son los mandados al servo, no una lectura sensorizada."));
}

void moveSelectedMotor(int delta) {
  int currentAngle = angleForMotor(selectedMotor);
  int nextAngle = constrain(
    currentAngle + delta,
    minAngleForMotor(selectedMotor),
    maxAngleForMotor(selectedMotor)
  );

  if (nextAngle == currentAngle) {
    Serial.println();
    Serial.println(F("Ya estas en el limite programado de ese motor."));
    printPose();
    return;
  }

  setAngleForMotor(selectedMotor, nextAngle);
  applyPose();
  printPose();
}

void selectMotor(int motor) {
  selectedMotor = motor;
  printPose();
}

void resetPose() {
  currentM1 = 90;
  currentM3 = 180;
  currentM4 = 180;
  currentM5 = 90;
  currentM6 = 10;
  applyPose();
  printPose();
}

void setup() {
  Serial.begin(9600);
  Braccio.begin();
  delay(2000);

  Serial.println(F("Calibracion manual del Braccio sin usar M2."));
  Serial.println(F("M2 se mantiene fijo y solo se prueban M1, M3, M4, M5 y M6."));
  printHelp();
  resetPose();
}

void loop() {
  if (!Serial.available()) {
    return;
  }

  char command = Serial.read();

  if (command == '\n' || command == '\r' || command == ' ') {
    return;
  }

  switch (command) {
    case '1':
      selectMotor(1);
      break;
    case '3':
      selectMotor(3);
      break;
    case '4':
      selectMotor(4);
      break;
    case '5':
      selectMotor(5);
      break;
    case '6':
      selectMotor(6);
      break;
    case 'd':
    case '+':
      moveSelectedMotor(angleStep);
      break;
    case 'a':
    case '-':
      moveSelectedMotor(-angleStep);
      break;
    case 'z':
      angleStep = 1;
      printPose();
      break;
    case 'x':
      angleStep = 5;
      printPose();
      break;
    case 'c':
      angleStep = 10;
      printPose();
      break;
    case 'p':
      printPose();
      break;
    case 'r':
      resetPose();
      break;
    case 'h':
    case '?':
      printHelp();
      printPose();
      break;
    default:
      Serial.println();
      Serial.print(F("Comando no reconocido: "));
      Serial.println(command);
      printHelp();
      printPose();
      break;
  }
}
