#include <Braccio.h>

void setup(){
 Braccio.begin();
}

void loop(){
 Braccio.ServoMovement(20, 0, 90, 90, 90, 90, 73);
 delay(1500);
 Braccio.ServoMovement(20, 45, 90, 90, 90, 90, 73);
 delay(1500);
 Braccio.ServoMovement(20, 90, 90, 90, 90, 90, 73);
 delay(1500);
 Braccio.ServoMovement(20, 135, 90, 90, 90, 90, 73);
 delay(1500);
 Braccio.ServoMovement(20, 180, 90, 90, 90, 90, 73);
 delay(1500);
}
